<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/faseCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_stats_card"
    android:padding="16dp"
    android:layout_marginBottom="14dp">

    <TextView
        android:id="@+id/faseTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fase mestruale"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/faseSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registros: 5 · Pasos medios: 4000"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sintomi più comuni"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:id="@+id/sintomiContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stati d'animo più comuni"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:layout_marginTop="14dp" />

    <LinearLayout
        android:id="@+id/moodContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp" />

</LinearLayout>