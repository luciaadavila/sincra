<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ligh_pink"
    tools:context=".MainActivity">

    <!-- FILA DE DIAS -->
    <LinearLayout
        android:id="@+id/calendarRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- DIA 1 -->
        <TextView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            android:gravity="center"
            android:text="1"
            android:textSize="18sp"
            android:background="@android:drawable/btn_default" />

        <!-- DIA 2 -->
        <TextView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            android:gravity="center"
            android:text="2"
            android:textSize="18sp"
            android:background="@android:drawable/btn_default" />

        <!-- DIA ACTUAL -->
        <TextView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="6dp"
            android:gravity="center"
            android:text="3"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/red"
            android:background="@android:drawable/btn_default" />

        <!-- DIA 4 -->
        <TextView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            android:gravity="center"
            android:text="4"
            android:textSize="18sp"
            android:background="@android:drawable/btn_default" />

        <!-- DIA 5 -->
        <TextView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            android:gravity="center"
            android:text="5"
            android:textSize="18sp"
            android:background="@android:drawable/btn_default" />

    </LinearLayout>

    <!-- BOTON PRINCIPAL -->
    <Button
        android:id="@+id/button_principal"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="DIA X&#10;FASE"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:backgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/calendarRow"
        app:layout_constraintBottom_toTopOf="@id/button_registro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <!-- BOTON VER REGISTRO -->
    <Button
        android:id="@+id/button_registro"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:text="VER REGISTRO"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/red"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>