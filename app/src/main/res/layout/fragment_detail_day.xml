<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ligh_pink">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/homeScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="96dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginBottom="24dp"
                            app:cardBackgroundColor="@android:color/white"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="3dp"
                            app:strokeWidth="0dp">

                                <TextView
                                    android:id="@+id/todayBar"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="DÍA 14"
                                    android:textColor="#444444"
                                    android:textSize="21sp"
                                    android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tvMoodTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stato_d_animo"
                            android:textColor="#3F3F3F"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMoodSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Come ti senti oggi?"
                            android:textColor="#777777"
                            android:textSize="14sp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/moodRecycler"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:minHeight="96dp"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddMood"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="14dp"
                            android:text="+"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:cornerRadius="18dp" />

                        <TextView
                            android:id="@+id/tvSymptomsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="30dp"
                            android:text="@string/sintomi"
                            android:textColor="#3F3F3F"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSymptomsSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Aggiungi i sintomi che hai notato"
                            android:textColor="#777777"
                            android:textSize="14sp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/symptomRecycler"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:minHeight="96dp"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddSymptom"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="14dp"
                            android:text="+"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:cornerRadius="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGuardar"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="36dp"
                            android:text="Salvare"
                            android:textAllCaps="false"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="18dp" />

                </LinearLayout>

        </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>